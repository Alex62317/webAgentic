__pycache__/
*.pyc
*.pyo
*.pyd

# 环境变量文件
.env

# 操作系统生成的文件
.DS_Store
Thumbs.db

# IDE生成的文件
.vscode/
.idea/
*.swp
*.swo
*~

# 依赖管理文件
node_modules/
package-lock.json

# 构建文件
build/
dist/
*.egg-info/

# 测试文件
.coverage
coverage.xml
pytest_cache/

# 临时文件
*.tmp
*.temp

# 其他
*.zip
*.tar.gz
*.rar